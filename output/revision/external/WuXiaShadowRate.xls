<div class="grid-frame" data-cols="3">
    

    <a href="https://afo-prod-cd.sitecore-prod-ase3.appserviceenvironment.net/who-we-are/careers" class="card action  ">
        <div class="card-content">
                        <h2 class="card-title">
                            Careers
                        </h2>

            <p>As an employee of the Atlanta Fed, you will help support our mission of promoting the stability, integrity, and efficiency of the US economy and financial system.</p>
            <div class="arrow-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none" role="img">
                    <title>Icon for Link Arrow</title>
