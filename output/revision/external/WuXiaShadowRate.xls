<dialog id="sendEmail" aria-label="Send email to contact">
    <button class="btn-close"><span class="sr-only">Close</span></button>
    <div class="modal-content">
        
    <form id="sendEmailForm" action="/data/sendEmail" method="post">

        <h2 class="h3 modal-title">Enter your information</h2>
        <p>
            <label for="SendEmailFirstName">First name <text>*</text></label><br />
            <input name="SendEmailFirstName" size="25" type="text" id="SendEmailFirstName" required />
        </p>
        <p>
            <label for="SendEmailLastName">Last name *</label><br />
            <input name="SendEmailLastName" size="25" type="text" id="SendEmailLastName" required />
        </p>
        <p>
            <label for="SendEmailEmailAddress">Email *</label><br />
            <input name="SendEmailEmailAddress" size="25" type="email" id="SendEmailEmailAddress" required />
        </p>
        <p>
            <label for="SendEmailMessage">Message *</label><br />
            <input name="SendEmailMessage" size="50" type="text" id="SendEmailMessage" required />
        </p>
        <p class="required">* Required field</p>
        <div class="form-actions">
            <input name="submit" type="submit" class="btn btn-primary" />
